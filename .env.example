# ==============================================================
# vm-platform – Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.
# ==============================================================

# ---------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------
DATABASE_URL=postgresql://admin:password@db:5432/vm_platform
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=vm_platform

# ---------------------------------------------------------------
# Auth – JWT secret used by @repo/auth to sign/verify sessions
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------
JWT_SECRET=

# ---------------------------------------------------------------
# Supabase – Server-side (never expose to the browser)
# ---------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------
# Supabase – Public (safe to expose to the browser)
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------
# App URLs – used for cross-app redirects and API calls
# ---------------------------------------------------------------
# Public-facing URL of the marketing / web app
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# URL of the secure operator dashboard (used by the gateway redirect)
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.yourdomain.com

# ---------------------------------------------------------------
# Upstash Redis - Serverless Rate Limiting
# ---------------------------------------------------------------
UPSTASH_REDIS_REST_URL="https://xxxxxxxxxxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
