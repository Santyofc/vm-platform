[Unit]
Description=VM Platform Web App (Docker Compose)
Requires=docker.service
After=docker.service network.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/vm-platform
ExecStart=/usr/bin/docker compose -p vm-platform -f infra/docker/docker-compose.prod.yml up -d
ExecStop=/usr/bin/docker compose -p vm-platform -f infra/docker/docker-compose.prod.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
